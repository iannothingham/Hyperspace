import pandas as pd
import re

route_name = "Rimma Trade Route"
speed_factor = 0.75

# Lecture du fichier texte
with open("Data/Raw/Rimma Trade Route.txt", "r") as f:
    raw_text = f.read()

planets = raw_text.split(" - ")
planets = [re.sub(r"\[\d+\]", "", planet).strip() for planet in planets]

# Création des nouveaux segments
rows = []

for i in range(len(planets) - 1):
    rows.append({
        "Route": route_name,
        "From": planets[i],
        "To": planets[i + 1],
        "Speed Factor": speed_factor
    })

new_df = pd.DataFrame(rows)

# Chargement du CSV existant
existing_df = pd.read_csv("Data/Processed/hyperlanes.csv", sep=";")

# Ajout des nouvelles lignes
final_df = pd.concat([existing_df, new_df], ignore_index=True)

# Sauvegarde
final_df.to_csv("Data/Processed/hyperlanes.csv", sep=";", index=False)

print(final_df)
